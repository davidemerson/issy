# issy configuration
#
# Place this file at ~/.issyrc (POSIX) or %APPDATA%\issy\config (Windows).
# Lines starting with # are comments. Unknown keys are ignored.

# ── Editing ──

# Number of spaces per tab stop
# tab_width = 4

# Insert spaces instead of tab characters
# expand_tabs = true

# Copy leading whitespace when pressing Enter
# auto_indent = true

# Automatically insert matching bracket/quote pairs
# auto_close_brackets = false

# Scan file on open to detect tabs vs spaces (overrides tab_width/expand_tabs per file)
# auto_detect_indent = true

# Minimum lines between cursor and screen edge before scrolling
# scroll_margin = 5

# ── Display ──

# Show line numbers in the gutter
# line_numbers = true

# Spaces before line numbers
# left_padding = 1

# Spaces between line numbers and code
# gutter_padding = 2

# Soft-wrap long lines at the right margin. Continuation lines are indented.
# word_wrap = true

# Soft right margin — code stops here, rest is empty background. 0 = fill terminal.
# right_margin = 100

# Subtle full-width highlight on the current line
# cursor_line_bg = true

# Terminal cursor shape: bar, block, or underline
# cursor_style = bar

# Faintly highlight trailing spaces/tabs on non-empty lines
# trailing_whitespace = true

# Faintly highlight leading indent that doesn't match the detected file style
# indent_mismatch = true

# ── PDF / Print ──

# Path to a TTF or OTF font file. Required for Ctrl+P and --print.
# font_file = "/Library/Fonts/Berkeley Mono Variable.ttf"

# Font size in points
# font_size = 10.0

# Page margins in points (72 points = 1 inch)
# print_margin_top = 72.0
# print_margin_bottom = 72.0
# print_margin_left = 108.0
# print_margin_right = 72.0

# ── Theme ──
#
# Uncomment one of the following to switch themes:
#   [theme.default]    — black background (this is the default)
#   [theme.paper]      — Solarized Light
#
# You can also override individual colors after the section header.
# Colors use #rrggbb hex format.

# [theme.paper]

# Override individual colors (default theme values shown):
# bg = "#000000"
# fg = "#b0b8c8"
# keyword = "#c4a0f7"
# string_color = "#a0d06e"
# comment = "#444c5e"
# number_color = "#b0b8c8"
# type_color = "#7dcfff"
# function_color = "#b0b8c8"
# operator_color = "#89ddff"
# preprocessor_color = "#e0af68"
# line_number_color = "#282c36"
# line_number_active = "#586070"
# cursor_line_color = "#0a0a0e"
# selection_color = "#1a2844"
# trailing_ws_color = "#1a1010"
# indent_mismatch_color = "#1a1010"
